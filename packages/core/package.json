{
  "name": "@react-kino/core",
  "version": "0.1.2",
  "description": "Framework-agnostic scroll engine powering react-kino",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4"
  },
  "author": "Bilal Tahir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/btahir/react-kino.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/btahir/react-kino#readme",
  "bugs": {
    "url": "https://github.com/btahir/react-kino/issues"
  }
}
